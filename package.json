{
  "name": "osero-sdk",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "changeset": "changeset",
    "version-packages": "changeset version",
    "ci:publish": "pnpm nx run-many -t build --projects='packages/*' && pnpm -r --filter './packages/*' publish --access public --no-git-checks",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "neverthrow": "^8.2.0",
    "viem": "^2.47.18"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@nx/js": "22.6.5",
    "@nx/vitest": "22.6.5",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "@vitest/coverage-v8": "~4.1.0",
    "ethers": "^6.16.0",
    "nx": "22.6.5",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "verdaccio": "^6.3.2",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  },
  "packageManager": "pnpm@10.30.3",
  "nx": {
    "includedScripts": [
      "lint",
      "lint:fix",
      "format",
      "format:check"
    ],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      },
      "lint": {
        "cache": true,
        "inputs": [
          "{workspaceRoot}/.oxlintrc.json",
          "{workspaceRoot}/packages/**/*.{ts,tsx,js,mjs,cjs}",
          "{workspaceRoot}/examples/**/*.{ts,tsx,js,mjs,cjs}"
        ]
      },
      "format:check": {
        "cache": true,
        "inputs": [
          "{workspaceRoot}/.oxfmtrc.json",
          "{workspaceRoot}/packages/**/*.{ts,tsx,js,mjs,cjs,json,md}",
          "{workspaceRoot}/examples/**/*.{ts,tsx,js,mjs,cjs,json,md}"
        ]
      }
    }
  }
}
